# ==============================================
# RetechFin Admin — variáveis de ambiente (Vite)
# ==============================================

# retechauth-api — login e CASL (/me → abilities)
# URL base SEM sufixo de path (o path está nos endpoints abaixo).
VITE_AUTH_BASE_URL=http://localhost:8080
VITE_AUTH_ENDPOINT_AUTHENTICATE=/v1/authenticate
VITE_AUTH_ENDPOINT_ME=/v1/me

# true = credenciais mock (demo@retechfin.com / demo123); false = API real
VITE_AUTH_USE_MOCK=true

# retechfin-api — domínio RetechFin (não usar no passo de autenticação)
VITE_API_BASE_URL=http://localhost:3001

# Legado / outros (se existirem no projeto)
# VITE_API_URL=
# VITE_APP_NAME=ReTechFin Admin
